{
  "name": "welkincss",
  "version": "1.0.0",
  "description": "Welkin — a CSS-first UI toolkit built on modern CSS: cascade layers, design tokens, container queries, zero required build step.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "css",
    "design-tokens",
    "cascade-layers",
    "container-queries",
    "dark-mode",
    "ui-toolkit",
    "no-build"
  ],
  "unpkg": "dist/welkin.min.css",
  "jsdelivr": "dist/welkin.min.css",
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./dist/welkin.css",
    "./welkin.css": "./dist/welkin.css",
    "./welkin.min.css": "./dist/welkin.min.css",
    "./welkin-core.css": "./dist/welkin-core.css",
    "./welkin-core.min.css": "./dist/welkin-core.min.css",
    "./components/*": "./dist/components/*",
    "./js/*": "./dist/js/*"
  },
  "scripts": {
    "build": "node build/build.mjs",
    "check:size": "node build/check-size.mjs",
    "test:a11y": "node test/a11y-smoke.mjs",
    "gen:appendix": "node build/gen-token-appendix.mjs",
    "lint": "stylelint \"src/**/*.css\" && node build/check-layer-line.mjs && node build/check-media-queries.mjs && node build/check-contrast.mjs && node build/gen-token-appendix.mjs --check",
    "test": "npm run lint && npm run build && npm run check:size",
    "prepublishOnly": "npm test",
    "build:site": "npm run build && node build/gen-site.mjs"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Edge versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "last 2 iOS major versions"
  ],
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "browserslist": "^4.24.0",
    "lightningcss": "^1.27.0",
    "marked": "^18.0.6",
    "playwright": "^1.61.1",
    "stylelint": "^16.10.0"
  }
}
