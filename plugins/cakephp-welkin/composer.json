{
    "name": "welkincss/cakephp-welkin",
    "description": "CakePHP plugin for the Welkin CSS toolkit: FormHelper templates emitting Welkin form-control markup, with server-side validation errors mapped to the aria-invalid contract.",
    "type": "cakephp-plugin",
    "license": "MIT",
    "keywords": ["cakephp", "plugin", "welkin", "css", "forms"],
    "require": {
        "php": ">=8.1",
        "cakephp/cakephp": "^5.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Welkin\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Welkin\\Test\\": "tests/"
        }
    },
    "extra": {
        "cakephp-plugins": {
            "Welkin": "."
        }
    }
}
